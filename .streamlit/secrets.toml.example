# Streamlit Cloud supports top-level secrets directly.
ENTSOE_API_KEY = "your_entsoe_api_key_here"
HF_TOKEN = "your_huggingface_token_here"

[general]
# Data config
ENTSOE_BIDDING_ZONE = "DE_LU"
ENTSOE_TIMEOUT_S = 90
ENTSOE_CHUNK_DAYS = 30
LOOKBACK_DAYS = 180
SEED = 42

# Open-Meteo coordinates (used only when a zone-specific mapping is unavailable)
OPENMETEO_LAT = 52.52
OPENMETEO_LON = 13.405

# Cache config
CACHE_SCHEMA_VERSION = 1
CACHE_ENABLED = true
CACHE_ATOMIC_WRITE_ENABLED = true
CACHE_REBUILD_DEFAULT = false
CACHE_MAX_GAP_FILL_HOURS = 720

# Hugging Face config
HF_MODEL = "Qwen/Qwen2.5-72B-Instruct"
HF_TIMEOUT_S = 30

# Backtest assumptions
TCOST_BPS = 5.0
ANNUALIZATION_FACTOR = 24
BACKTEST_NOTIONAL_EUR = 10000.0

# Signal config
ENABLE_NEW_SIGNAL = true
SIGNAL_VOL_WINDOW_HOURS = 24
SIGNAL_POSITION_SCALE_K = 2.0
ENABLE_VOLATILITY_SCALING = true
ENABLE_EXECUTION_DELAY = true
SIGNAL_EQUILIBRIUM_WINDOW_HOURS = 72
SIGNAL_IMBALANCE_SCALE = 8.0
SIGNAL_FORECAST_WEIGHT = 0.45
SIGNAL_MEAN_REVERSION_WEIGHT = 0.30
SIGNAL_FUNDAMENTAL_WEIGHT = 0.25
LONG_PRICE_EDGE_THRESHOLD = 0.5
SHORT_PRICE_EDGE_THRESHOLD = -0.5
ENABLE_REGIME_SWITCHING = true
HIGH_VOL_REGIME_QUANTILE = 0.7

# Trading and execution
POSITION_LIMIT = 1.0
MAX_POSITION_CHANGE = 0.35
BID_ASK_SPREAD_BPS = 3.0
BID_ASK_SPREAD_EUR_MWH = 0.0
SLIPPAGE_VOLATILITY_FACTOR = 0.08
SLIPPAGE_TURNOVER_FACTOR = 0.02
DELAY_PENALTY_FACTOR = 0.03

# Evaluation and research
BOOTSTRAP_ITERATIONS = 250
WALK_FORWARD_TRAIN_WINDOW_DAYS = 90
WALK_FORWARD_TEST_WINDOW_DAYS = 7
LLM_OPTIONAL_MODE = true
