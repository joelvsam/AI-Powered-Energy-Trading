# Required secrets
ENTSOE_API_KEY=your_entsoe_api_key_here
HF_TOKEN=your_huggingface_token_here

# Optional model config
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
HF_TIMEOUT_S=30

# Data config
ENTSOE_BIDDING_ZONE=DE_LU
LOOKBACK_DAYS=180
SEED=42

# Open-Meteo coordinates (Berlin default)
OPENMETEO_LAT=52.52
OPENMETEO_LON=13.405

# Backtest assumptions
TCOST_BPS=5.0
ANNUALIZATION_FACTOR=24
